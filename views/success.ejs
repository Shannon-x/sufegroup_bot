<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>验证成功</title>
    <link rel="stylesheet" href="/css/modern-verify.css">
</head>
<body>
    <div class="page">
        <div class="card">
            <div class="success-wrap">
                <div class="success-icon">
                    <svg viewBox="0 0 24 24">
                        <path d="M5 13l4 4L19 7"/>
                    </svg>
                </div>

                <h1 class="success-title">验证成功</h1>
                <p class="success-desc">您已通过验证，现在可以在群组中正常发言了。</p>

                <div class="success-actions">
                    <a href="tg://resolve?domain=<%= botUsername %>" class="btn-primary">
                        返回 Telegram
                    </a>
                </div>

                <p class="redirect-hint">将在 <span id="countdown">5</span> 秒后自动跳转…</p>
            </div>
        </div>
    </div>

    <script>
        var sec = 5;
        var el = document.getElementById('countdown');
        var timer = setInterval(function() {
            sec--;
            el.textContent = sec;
            if (sec <= 0) {
                clearInterval(timer);
                window.location.href = 'tg://resolve?domain=<%= botUsername %>';
            }
        }, 1000);
    </script>
</body>
</html>
