<!DOCTYPE html>
<html lang="zh-CN" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>小菲 · 管理面板</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
<script src="https://js.hcaptcha.com/1/api.js?render=explicit" async defer></script>
<link rel="stylesheet" href="/css/mini-app.css">
</head>
<body>

<!-- Theme toggle (always visible) -->
<button class="theme-fab" id="btn-theme" title="切换主题">🌙</button>

<!-- Loading -->
<div id="screen-loading">
  <div class="spin"></div>
  <span style="color:var(--text2)">加载中...</span>
</div>

<!-- Error -->
<div id="screen-error">
  <div style="font-size:44px;margin-bottom:4px">⚠️</div>
  <p id="err-msg"></p>
</div>

<!-- Verification -->
<div id="screen-verify">
  <div class="verify-card">
    <div class="verify-header">
      <div class="verify-icon">🔐</div>
      <div class="verify-title" id="v-title">入群验证</div>
      <div class="verify-sub" id="v-sub">请完成人机验证以加入群组</div>
      <div class="verify-group-badge" id="v-group-badge">
        <span class="verify-group-dot"></span>
        <span id="v-group-name">加载中...</span>
      </div>
    </div>

    <div class="verify-user" id="v-user-section" style="display:none;">
      <div class="verify-avatar" id="v-avatar"></div>
      <div>
        <div class="verify-uname" id="v-uname"></div>
        <div class="verify-handle" id="v-handle"></div>
      </div>
    </div>

    <div class="verify-timer" id="v-timer-section" style="display:none;">
      <div class="verify-timer-row">
        <span class="verify-timer-label">⏱ 剩余时间</span>
        <span class="verify-timer-value" id="v-timer">--:--</span>
      </div>
      <div class="verify-bar">
        <div class="verify-bar-fill" id="v-bar" style="width:100%"></div>
      </div>
    </div>

    <% if (typeof hcaptchaSiteKey !== 'undefined' && hcaptchaSiteKey) { %>
    <div id="v-dual-nav" style="display:none;">
      <div class="v-warn">⚠️ 电脑端遇到“正在验证…”一直卡住？<br>请在下方尝试切换为 hCaptcha</div>
      <div class="lb-tabs" style="margin-bottom:12px;">
        <div class="lb-tab active" id="v-tab-cf">🛡 CF 无感 (推荐)</div>
        <div class="lb-tab" id="v-tab-hc">🧩 hCaptcha</div>
      </div>
    </div>
    <% } %>

    <div class="verify-captcha" id="v-captcha">
      <div class="verify-captcha-wrap" id="v-turnstile-container"></div>
      <% if (typeof hcaptchaSiteKey !== 'undefined' && hcaptchaSiteKey) { %>
      <div class="verify-captcha-wrap" id="v-hcaptcha-container" style="display:none;"></div>
      <% } %>
      <button class="verify-btn" id="v-submit" disabled>完成验证</button>
      <div class="verify-msg error" id="v-error"></div>
      <div class="verify-msg success" id="v-success"></div>
    </div>
  </div>
</div>

<!-- Verification success overlay -->
<div class="verify-success-overlay" id="screen-verify-done">
  <div class="verify-check">✓</div>
  <div class="verify-done-title">验证成功！</div>
  <div class="verify-done-sub" id="v-done-sub">您已通过验证，现在可以正常发言了。</div>
  <button class="verify-done-close" id="v-done-close">关闭</button>
</div>

<!-- Leaderboard -->
<div id="screen-leaderboard">
  <div class="lb-header">
    <div class="lb-title">🏆 群组排名</div>
    <div class="lb-sub" id="lb-group-name">加载中...</div>
  </div>

  <div class="lb-tabs">
    <div class="lb-tab active" id="lb-btn-xp">🌟 活跃榜 (经验)</div>
    <div class="lb-tab" id="lb-btn-coins">💰 财富榜 (积分)</div>
  </div>

  <div id="lb-my-score" style="margin-bottom: 12px;"></div>

  <div class="lb-list" id="lb-list-container">
    <!-- Items populated by JS -->
  </div>

  <div class="lb-faq">
    <div class="lb-faq-title">💡 积分与经验有什么区别？</div>
    <div class="lb-faq-text">
      <b>🌟 经验 (XP)</b>：代表您的群活度，通过每日群内聊天和签到自动获取。经验值决定了您的<b>等级与称号</b>，仅作群地位展示，无法消费或减少。
    </div>
    <div class="lb-faq-text">
      <b>💰 积分 (Coins)</b>：代表您的虚拟财富，主要通过完成每日签到获取。积分可以被<b>作为货币消耗</b>，例如用于参与需要费用的抽奖活动等。
    </div>
  </div>
</div>

<!-- Group list -->
<div id="screen-groups">
  <div class="page-title">管理面板</div>
  <div class="page-sub">选择要管理的群组</div>
  <div id="group-list"></div>
</div>

<!-- Settings panel -->
<div id="screen-panel" style="flex-direction:column;">
  <div class="panel-hd">
    <button class="icon-btn" id="btn-back">← 返回</button>
    <span class="panel-hd-name" id="panel-name"></span>
    <button class="icon-btn" id="btn-refresh">↻</button>
  </div>
  <div class="tab-bar">
    <button class="tab-btn active" data-tab="basic">⚙️ 设置</button>
    <button class="tab-btn" data-tab="filter">🛡 过滤</button>
    <button class="tab-btn" data-tab="flood">🌊 刷屏</button>
    <button class="tab-btn" data-tab="titles">🏷 称号</button>
    <button class="tab-btn" data-tab="lottery">🎰 抽奖</button>
  </div>
  <div class="tab-contents">

    <!-- ⚙️ 设置 -->
    <div id="tab-basic" class="tab-pane active">
      <div class="sec">
        <div class="sec-hd">入群验证</div>
        <div class="card">
          <div class="row">
            <div><div class="row-lbl">入群验证</div><div class="row-sub">新成员需完成验证才能发言</div></div>
            <div class="tog" id="t-verify"></div>
          </div>
          <div class="row">
            <div class="row-lbl">验证时长</div>
            <button class="cyc" id="btn-ttl">--</button>
          </div>
          <div class="row">
            <div><div class="row-lbl">超时处理</div><div class="row-sub">验证超时后的操作</div></div>
            <button class="cyc" id="btn-auto-action">--</button>
          </div>
        </div>
      </div>
    </div>

    <!-- 🛡 过滤 -->
    <div id="tab-filter" class="tab-pane">
      <div class="sec">
        <div class="sec-hd">内容过滤</div>
        <div class="card">
          <div class="row">
            <div class="row-lbl">内容过滤总开关</div>
            <div class="tog" id="t-filter"></div>
          </div>
          <div class="row">
            <div class="row-lbl">链接过滤</div>
            <div class="tog" id="t-urls"></div>
          </div>
          <div class="row">
            <div class="row-lbl">邀请链接过滤</div>
            <div class="tog" id="t-invite"></div>
          </div>
          <div class="row">
            <div class="row-lbl">手机号过滤</div>
            <div class="tog" id="t-phone"></div>
          </div>
          <div class="row">
            <div class="row-lbl">频道转发过滤</div>
            <div class="tog" id="t-forward"></div>
          </div>
          <div class="row">
            <div><div class="row-lbl">违规处理方式</div><div class="row-sub">点击切换</div></div>
            <button class="cyc" id="btn-filter-action">--</button>
          </div>
          <div class="row">
            <div><div class="row-lbl">警告上限</div><div class="row-sub">超出后升级处罚</div></div>
            <button class="cyc" id="btn-max-warn">--</button>
          </div>
        </div>
      </div>
      <div class="sec">
        <div class="sec-hd">自定义关键词</div>
        <div class="card">
          <div id="kw-list"></div>
          <div class="add-row">
            <input type="text" id="kw-input" class="inp"
              placeholder="输入关键词后按添加"
              maxlength="50"
              autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
            <button class="add-btn" id="btn-add-kw">添加</button>
          </div>
        </div>
      </div>
    </div>

    <!-- 🌊 刷屏 -->
    <div id="tab-flood" class="tab-pane">
      <div class="sec">
        <div class="sec-hd">防刷屏设置</div>
        <div class="card">
          <div class="row">
            <div class="row-lbl">防刷屏总开关</div>
            <div class="tog" id="t-flood"></div>
          </div>
          <div class="row">
            <div><div class="row-lbl">消息限制</div><div class="row-sub">点击切换预设</div></div>
            <button class="cyc" id="btn-flood-preset">--</button>
          </div>
          <div class="row">
            <div><div class="row-lbl">触发后操作</div><div class="row-sub">点击切换</div></div>
            <button class="cyc" id="btn-flood-action">--</button>
          </div>
          <div class="row">
            <div><div class="row-lbl">禁言时长</div><div class="row-sub">仅禁言操作时有效</div></div>
            <button class="cyc" id="btn-flood-mute">--</button>
          </div>
        </div>
      </div>
    </div>

    <!-- 🏷 称号 -->
    <div id="tab-titles" class="tab-pane">
      <div class="sec">
        <div class="sec-hd">等级称号列表</div>
        <div class="card" id="titles-card"></div>
      </div>
      <div class="sec">
        <div class="sec-hd">添加 / 修改称号</div>
        <div class="card">
          <div class="add-row">
            <span style="font-size:13px;color:var(--text3);flex-shrink:0;font-weight:500;">Lv.</span>
            <input type="number" id="title-lv" class="inp inp-sm"
              placeholder="等级" min="1" max="999"
              inputmode="numeric" autocomplete="off">
            <input type="text" id="title-txt" class="inp"
              placeholder="称号名称（支持 emoji）"
              maxlength="30"
              autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
              enterkeyhint="done">
            <button class="add-btn" id="btn-add-title">确认</button>
          </div>
        </div>
      </div>
      <button class="danger-btn" id="btn-reset-titles">↩ 恢复默认称号</button>
    </div>

    <!-- 🎰 抽奖 -->
    <div id="tab-lottery" class="tab-pane">
      <div class="sec">
        <div class="sec-hd">进行中的抽奖</div>
        <div class="card" id="lottery-card">
          <div class="empty">
            <span class="spin" style="vertical-align:middle;margin-right:6px;display:inline-block;"></span>加载中...
          </div>
        </div>
      </div>
      <div class="sec">
        <div class="sec-hd">创建新抽奖</div>
        <div class="card">
          <div class="form-row">
            <div class="form-lbl">🎁 奖品名称</div>
            <input type="text" id="lt-prize" class="inp"
              placeholder="例：红包20元、VIP月卡"
              maxlength="100"
              autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
              enterkeyhint="next">
          </div>
          <div class="form-row">
            <div class="form-lbl">👥 中奖人数（1 – 50）</div>
            <input type="number" id="lt-count" class="inp" value="1" min="1" max="50" inputmode="numeric">
          </div>
          <div class="form-row">
            <div class="form-lbl">⏱ 持续时长</div>
            <select id="lt-dur" class="form-sel">
              <option value="15">15 分钟</option>
              <option value="30" selected>30 分钟</option>
              <option value="60">1 小时</option>
              <option value="120">2 小时</option>
              <option value="360">6 小时</option>
              <option value="720">12 小时</option>
              <option value="1440">24 小时</option>
            </select>
          </div>
          <div class="form-row">
            <div class="form-lbl">📊 最低等级（0 = 不限）</div>
            <input type="number" id="lt-level" class="inp" value="0" min="0" max="100" inputmode="numeric">
          </div>
          <div class="form-row">
            <div class="form-lbl">💰 参与费用积分（0 = 免费）</div>
            <input type="number" id="lt-coins" class="inp" value="0" min="0" inputmode="numeric">
          </div>
          <button class="form-sub" id="btn-create-lt">🎰 创建抽奖</button>
        </div>
      </div>
    </div>

  </div><!-- /tab-contents -->
</div><!-- /screen-panel -->

<div id="toast"></div>

<script>
window.MINIAPP_CONFIG = {
  siteKey: '<%= typeof siteKey !== "undefined" ? siteKey : "" %>',
  hcaptchaSiteKey: '<%= typeof hcaptchaSiteKey !== "undefined" ? hcaptchaSiteKey : "" %>'
};
</script>
<script src="/js/mini-app/core.js"></script>
<script src="/js/mini-app/panel.js"></script>
<script src="/js/mini-app/events.js"></script>
<script src="/js/mini-app/verification.js"></script>
<script src="/js/mini-app/leaderboard.js"></script>
</body>
</html>
